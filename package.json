{
  "name": "ai-price-compare-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "deploy": "bash scripts/deploy.sh",
    "deploy:win": "scripts\\deploy.bat",
    "db:init": "wrangler d1 execute ai-price-compare --local --file=./migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute ai-price-compare --remote --file=./migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute ai-price-compare --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute ai-price-compare --remote --file=./migrations/0002_seed.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.0",
    "wrangler": "^3.57.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
